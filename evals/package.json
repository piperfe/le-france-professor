{
  "name": "le-france-professor-evals",
  "version": "1.0.0",
  "description": "Automated conversation evaluation harness for Le France Professor",
  "private": true,
  "scripts": {
    "test": "jest --testPathIgnorePatterns='integration' --watchAll=false",
    "test:integration": "jest --testPathPattern='integration' --watchAll=false",
    "test:all": "jest --watchAll=false",
    "typecheck": "tsc --noEmit",
    "eval": "tsx src/cli.ts run",
    "compare": "tsx src/cli.ts compare"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "node-fetch": "^2.7.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/node-fetch": "^2.6.12",
    "jest": "^29.7.0",
    "nock": "^14.0.11",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.2"
  }
}
